# Environment Variables for Token Holder Leaderboard Tracker

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Blockchain Configuration (REQUIRED)
RPC_URL=https://dream.somnia.network
TOKEN_ADDRESS=0x597512cbdf1De65AbEEdA7b927A1fB054D2afef7

# Optional: Deployment block number (for faster event scanning)
# Find this from your token deployment transaction
DEPLOYMENT_BLOCK=0

# RECOMMENDED: The Graph Subgraph (fastest for 100K+ holders)
# Create a subgraph at https://thegraph.com/studio/
# Queries complete in seconds vs 30+ minutes with direct RPC
GRAPH_ENDPOINT=https://api.thegraph.com/subgraphs/name/your-username/your-subgraph

# Alternative: Moralis API (if The Graph not available)
# Sign up at https://moralis.io
MORALIS_API_KEY=your-moralis-key-here

# Alternative: Alchemy API
# Sign up at https://alchemy.com
ALCHEMY_API_KEY=your-alchemy-key-here

# Alternative: Covalent API
# Sign up at https://www.covalenthq.com/
COVALENT_API_KEY=your-covalent-key-here

# Performance Tuning (optional)
BATCH_SIZE=500              # Holders processed per batch (default: 500)
CONCURRENCY_LIMIT=10        # Max parallel RPC calls (default: 10)
